menu "PIGLR MQTT Config"

config MQTT_SAMPLE_CLIENT_ID
    string "MQTT Client ID"
    default ""
    help
      If empty, client ID will be generated from IMEI (nRF91).

config MQTT_SAMPLE_BROKER_HOSTNAME
    string "MQTT broker hostname"
    default "piglr.duckdns.org"

config LR_MQTT_USERNAME
    string "MQTT username"
    default ""

config LR_MQTT_PASSWORD
    string "MQTT password"
    default ""

config PAIR_ID
    string "Pair ID"
    default "P123"

config MY_ID
    string "My device ID"
    default "devA"

config PEER_ID
    string "Peer device ID"
    default "devB"

endmenu

source "Kconfig.zephyr"